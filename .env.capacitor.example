# Capacitor iOS/Android build (npm run build:capacitor / build:ios)
# Copy to .env.capacitor and fill VITE_SUPABASE_* from your main .env.

VITE_APPLE_OAUTH_ENABLED=true

# REQUIRED for AI on device: HTTPS root of the deployment that serves /api/assistant/*
VITE_ASSISTANT_API_BASE_URL=https://your-pet-care-app.vercel.app
